            x: 0,
            y: 3,
            w: 12,
            h: 2,
          },
          display: {
            columns: [
              { key: "task_name", label: "事项名称" },
              { key: "creditor", label: "关联债权人" },
              { key: "due_date", label: "截止日期" },
              { key: "assignee", label: "负责人" },
              { key: "priority", label: "优先级" },
              { key: "status", label: "状态" },
            ],
          },
        },
      ],
    },
  },
]
ON DUPLICATE KEY UPDATE
  label = $input.label,
  icon = $input.icon,
  accent = $input.accent,
  default_name = $input.default_name,
  description = $input.description,
  builtin = $input.builtin,
  sort_order = $input.sort_order,
  column_defs = $input.column_defs,
  sheet_defs = $input.sheet_defs,
  quick_tasks = $input.quick_tasks,
  row_analysis = $input.row_analysis,
  default_dashboard = $input.default_dashboard;

{
  "name": "surreal-ck",
  "version": "0.1.0",
  "description": "Graph-powered collaborative spreadsheet — table = database table",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @surreal-ck/server dev",
    "dev:server": "pnpm --filter @surreal-ck/server dev",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r run typecheck",
    "icon:generate": "node scripts/generate-app-icons.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "server",
    "web",
    "shared"
  ]
}

{
  "name": "surreal-ck",
  "version": "0.1.0",
  "description": "Graph-powered collaborative spreadsheet — table = database table",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite build && bun run scripts/filter-surrealdb-timestamp-stderr.ts -- electrobun dev --watch",
    "build": "vite build --config vite.config.ts && electrobun build",
    "icon:generate": "node scripts/generate-app-icons.mjs",
    "start": "bun run scripts/filter-surrealdb-timestamp-stderr.ts -- electrobun run",
    "test": "bun run scripts/filter-surrealdb-timestamp-stderr.ts -- bun test src/main",
    "test:db": "bun run scripts/filter-surrealdb-timestamp-stderr.ts -- bun run scripts/test-db.ts",
    "test:bootstrap": "bun run scripts/filter-surrealdb-timestamp-stderr.ts -- bun run scripts/test-app-bootstrap.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.32.0",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.17.5",
    "@mastra/observability": "^1.11.1",
    "@surrealdb/node": "^3.0.3",
    "dayjs": "^1.11.20",
    "electrobun": "^1.16.0",
    "layerchart": "2.0.0-next.62",
    "marked": "^18.0.3",
    "mastra": "^1.8.0",
    "surrealdb": "^2.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@revolist/svelte-datagrid": "^4.21.3",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/three": "^0.184.0",
    "bun-types": "^1.3.12",
    "concurrently": "^9.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vite-plugin-static-copy": "^4.1.0"
  }
}

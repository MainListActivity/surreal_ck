{
  "name": "surreal-ck",
  "version": "0.1.0",
  "description": "Graph-powered collaborative spreadsheet — table = database table",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "concurrently \"vite build --watch --config vite.config.ts\" \"electrobun dev --watch\"",
    "build": "vite build --config vite.config.ts && electrobun build",
    "start": "electrobun run",
    "test": "bun test src/main",
    "test:db": "bun run scripts/test-db.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.25.0",
    "@surrealdb/node": "^3.0.3",
    "electrobun": "^1.16.0",
    "surrealdb": "^2.0.3"
  },
  "devDependencies": {
    "@revolist/svelte-datagrid": "^4.21.3",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/three": "^0.184.0",
    "bun-types": "^1.3.12",
    "concurrently": "^9.0.0",
    "svelte": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9"
  }
}

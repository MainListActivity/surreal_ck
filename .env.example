# Bun server
PORT=8080
NODE_ENV=development

# SurrealDB
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_NS=main
SURREAL_ROOT_USER=root
SURREAL_ROOT_PASS=change_me

# OIDC
OIDC_ISSUER=https://o.maplayer.top/t/ck
OIDC_JWKS_URL=https://o.maplayer.top/t/ck/jwks.json
OIDC_AUDIENCE=https://auth.maplayer.top
# 后端 confidential client 用于代理 authorization_code token exchange；不要放入 VITE_*。
OIDC_CLIENT_ID=change_me
OIDC_CLIENT_SECRET=change_me
OIDC_TOKEN_ENDPOINT=https://o.maplayer.top/t/ck/token
# 必须与 IdP 中该 web client 的 token_endpoint_auth_method 一致。
OIDC_TOKEN_AUTH_METHOD=client_secret_basic

# IdP token scope adapter / hook
IDP_SCOPE_API_URL=https://o.maplayer.top/t/ck/scope
# 与 IdP（ma_hono）的 CLAIM_HOOK_SECRET 对齐；登录 hook（default-scope）的 Bearer 鉴权
IDP_HOOK_SECRET=change_me_hook_secret

# _system 管理员 allowlist：逗号分隔的 OIDC subject。名单内用户登录可创建 workspace
# （登录 hook 返回 can_create_workspace=true；无 workspace 时落 _system db）。留空则无人可建。
SYSTEM_ADMIN_SUBJECTS=

# _system index 校对心跳间隔（秒）；启动跑一次后按此周期重复
RECONCILE_INTERVAL_SEC=3600

# Mastra 可观测性 span/event 保留天数（缺省 30）；过期由 SurrealDB expires_at 兜底清理
MASTRA_OBSERVABILITY_RETENTION_DAYS=30

# AI 模型 provider / model / key（生产装配 AiChatService 用；三者齐备才接线，否则 /api/chat 返回 501）。
# 示例：AI_PROVIDER=anthropic AI_MODEL=claude-sonnet-4-5 AI_API_KEY=sk-ant-...
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
# 可选自定义 endpoint（OpenAI 兼容代理 / 本地推理）
AI_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────
# 前端构建（Vite 从仓库根读 .env，见 web/vite.config.ts envDir: ".."）。
# 这些 VITE_* 会被打进前端 bundle，只能放公开值；不要放任何 secret。
# 缺 VITE_SURREAL_URL 时浏览器直连 SurrealDB 会在 connectSurreal 抛错。
# ─────────────────────────────────────────────────────────────────────────
# 浏览器直连 SurrealDB 的 WSS 地址（公网 TLS）；dev 可用 ws://localhost:8000/rpc
VITE_SURREAL_URL=ws://localhost:8000/rpc
# Bun server 对外地址；dev 走 vite 代理时填相对路径 /api 即可
VITE_API_BASE_URL=/api
# OIDC SPA 登录壳（oidc-client-ts）；issuer / audience 与后端 OIDC_* 对齐
VITE_OIDC_ISSUER=https://o.maplayer.top/t/ck
VITE_OIDC_AUDIENCE=https://auth.maplayer.top
# 前端 public client（PKCE，无 secret），与后端 confidential client 不是同一个
VITE_OIDC_CLIENT_ID=change_me
# 登录回调地址；dev 默认 vite 端口
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback

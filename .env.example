# Bun server
PORT=8080
NODE_ENV=development

# SurrealDB
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_NS=main
SURREAL_ROOT_USER=root
SURREAL_ROOT_PASS=change_me

# OIDC
OIDC_ISSUER=https://o.maplayer.top/t/ck
OIDC_JWKS_URL=https://o.maplayer.top/t/ck/jwks.json
OIDC_AUDIENCE=https://auth.maplayer.top

# IdP token scope adapter / hook
IDP_SCOPE_API_URL=https://o.maplayer.top/t/ck/scope
IDP_SCOPE_API_TOKEN=change_me
# 与 IdP（ma_hono）的 CLAIM_HOOK_SECRET 对齐；登录 hook（default-scope）的 Bearer 鉴权
IDP_HOOK_SECRET=change_me_hook_secret

# _system 管理员 allowlist：逗号分隔的 OIDC subject。名单内用户登录可创建 workspace
# （登录 hook 返回 can_create_workspace=true；无 workspace 时落 _system db）。留空则无人可建。
SYSTEM_ADMIN_SUBJECTS=

# _system index 校对心跳间隔（秒）；启动跑一次后按此周期重复
RECONCILE_INTERVAL_SEC=3600

# Mastra 可观测性 span/event 保留天数（缺省 30）；过期由 SurrealDB expires_at 兜底清理
MASTRA_OBSERVABILITY_RETENTION_DAYS=30

# AI 模型 provider / model / key（生产装配 AiChatService 用；三者齐备才接线，否则 /api/chat 返回 501）。
# 示例：AI_PROVIDER=anthropic AI_MODEL=claude-sonnet-4-5 AI_API_KEY=sk-ant-...
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
# 可选自定义 endpoint（OpenAI 兼容代理 / 本地推理）
AI_BASE_URL=

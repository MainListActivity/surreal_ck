{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@surreal-ck/shared": ["../shared/src/index.ts"],
      "@surreal-ck/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "ai/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}

    "@surreal-ck/shared": "workspace:*",
    "hono": "^4.12.14",
    "jose": "^6.1.3",
    "surrealdb": "^2.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.12"
  }
}

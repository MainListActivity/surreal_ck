{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["svelte", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@surreal-ck/shared": ["../shared/src/index.ts"],
      "@surreal-ck/shared/workspace-template": ["../shared/dist/sql/workspace-template/index.d.ts"],
      "@surreal-ck/shared/*": ["../shared/src/*"],
      "@surreal-ck/server/app-type": ["../server/dist/server/src/app.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "exclude": ["node_modules", "legacy", "**/*.test.ts"]
}

{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "node_modules/.pnpm/bun-types@1.3.12/node_modules",
      "node_modules/@types"
    ],
    "types": ["bun-types"]
  },
  "include": ["bun/**/*.ts"]
}
